# ============================================================
# CoreX Bridge — Variables de entorno
# Copiar este archivo como .env y ajustar los valores
# ============================================================

# --- MQTT ---
MQTT_BROKER=mqtt://127.0.0.1

# --- UDP (AgOpenGPS) ---
UDP_PORT=17777
AOG_BROADCAST_IP=127.0.0.1
AOG_PORT_OUT=17777

# --- API QuantiX ---
CONFIG_URL=http://localhost:8080/api/gis/config-implemento
QUANTIX_SYNC_MS=30000

# --- Ruta a los campos de AgOpenGPS ---
# Windows ejemplo: C:\Users\Cabina\Documents\AgOpenGPS\Fields
# Linux/RPi ejemplo: /home/pi/Documents/AgOpenGPS/Fields
# Si se deja vacío, se usa la carpeta Documents del usuario actual
AOG_FIELDS_PATH=
CURRENT_FIELD_PATH=

# --- Umbrales operativos ---
# Velocidad mínima (km/h) para considerar que la máquina está sembrando
VEL_MIN_PINTADO=0.5

# --- Logging ---
# DEBUG_LEVEL 0-3 (0=silent, 1=info, 2=verbose, 3=trace). Cambiable en runtime
# por MQTT: `mosquitto_pub -t corex/debug/level -m 2`
DEBUG_LEVEL=1
# Formato de log: 'text' (default, colores ANSI) o 'json' (structured, un
# objeto JSON por línea — ideal para ELK/Loki/jq)
LOG_FORMAT=text
# AOGLOG_DEBUG=0 desactiva logs verbose del field-watcher
AOGLOG_DEBUG=1

# --- Observabilidad ---
# HTTP endpoint con /healthz /metrics /version. 0=OS-assigned, <0=deshabilitado
HEALTH_PORT=9090
